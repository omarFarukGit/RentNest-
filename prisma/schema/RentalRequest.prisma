model RentalRequest {
    id          String        @id @default(uuid())
    propertyId  String
    landlordId  String
    tenantId    String
    message     String?
    status      RequestStatus @default(PENDING)
    startDate   DateTime
    endDate     DateTime
    property    Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
    landlord    User          @relation("landlordRequests", fields: [landlordId], references: [id])  
    tenant      User          @relation("tenantRequests", fields: [tenantId], references: [id])      
    payment     Payment?
    createdAt   DateTime      @default(now())
    updatedAt   DateTime      @updatedAt

    @@map("rental_requests")
}


enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED 
}